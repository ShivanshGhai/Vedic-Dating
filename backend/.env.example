# ── Database (Railway MySQL) ──────────────────────────────────────────────
DB_HOST=your-railway-mysql-host.railway.app
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_railway_db_password
DB_NAME=railway

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_string_at_least_64_chars
JWT_EXPIRES_IN=7d

# ── Server ────────────────────────────────────────────────────────────────
PORT=4000
FRONTEND_URL=https://your-frontend.up.railway.app

# ── Prokerala Astrology API ───────────────────────────────────────────────
# Sign up free at https://api.prokerala.com
PROKERALA_CLIENT_ID=your_client_id
PROKERALA_CLIENT_SECRET=your_client_secret

# ── Email (Nodemailer via Gmail App Password) ─────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail@gmail.com
SMTP_PASS=your_gmail_app_password
EMAIL_FROM="Ashtakoota ✦ <your_gmail@gmail.com>"

# ── Avatar uploads (local for dev; swap to S3/Cloudflare R2 for prod) ────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5
